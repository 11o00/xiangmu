{
  "packages": [
    "openjdk@17",
    "mysql80"
  ],
  "shell": {
    "init_hook": [
      "export NIX_CURL_FLAGS=\"--ipv4 --connect-timeout 10 --max-time 120 --retry 5 --retry-delay 2\"",
      "export NIX_CONFIG=$'connect-timeout = 60\\nmax-jobs = auto\\ncores = 0\\nhttp-connections = 50\\n'",
      "export JAVA_HOME=\"$(dirname $(dirname $(readlink -f $(which java))))\"",
      "export PATH=\"$JAVA_HOME/bin:$PATH\""
    ]
  }
}
